# Copy to .env and fill in real values:  cp .env.example .env
# Used by Schemas/CockroachDB/mindshare_score_test/Scripts/ (loaded via python-dotenv).

# Option 1 (preferred): full connection string.
# Local insecure cluster:
DATABASE_URL=postgresql://root@localhost:26257/defaultdb?sslmode=disable
# CockroachDB Cloud shape:
# DATABASE_URL=postgresql://<user>:<password>@<host>:26257/defaultdb?sslmode=verify-full

# Option 2: discrete parts, used only when DATABASE_URL is unset/empty.
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=26257
# DB_NAME=defaultdb
# DB_SSLMODE=disable
